# =============================================================================
# Suvidha Pharmacy Pro - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# For Render: set these in the Dashboard → Service → Environment.
# For Vercel: set these in Project → Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED (for full app)
# -----------------------------------------------------------------------------

# PostgreSQL connection string (Neon, Supabase, Render Postgres, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# -----------------------------------------------------------------------------
# BACKEND (Render – Node.js Web Service)
# -----------------------------------------------------------------------------

# Set by Render automatically; override only if needed
# PORT=5000

# Secret for sessions and JWT (use a long random string in production)
SESSION_SECRET=your-long-random-secret-change-in-production

# -----------------------------------------------------------------------------
# AI MICROSERVICE (Render – second Web Service, Python)
# -----------------------------------------------------------------------------
# Yes, you need a separate Render Web Service for the Python AI app.
# 1. Create first service: Node.js (this repo, build: npm run build, start: npm start)
# 2. Create second service: Python (root: ai-service, build: pip install -r requirements.txt, start: python app.py)
# 3. After deploy, copy the Python service URL and set AI_SERVICE_URL in the Node service.

# URL of the Python AI service (optional; omit to disable AI features)
AI_SERVICE_URL=https://your-ai-service-name.onrender.com

# -----------------------------------------------------------------------------
# FRONTEND ON VERCEL (optional)
# -----------------------------------------------------------------------------
# If you host the frontend on Vercel and the API on Render, set this in Vercel
# to the full URL of your Render backend (e.g. https://suvidha-api.onrender.com).
# The app must be built to use this (see guide.md). Default: same origin (no split).
# VITE_API_URL=https://your-backend.onrender.com

# -----------------------------------------------------------------------------
# CORS (Render backend only – when using Vercel for frontend)
# -----------------------------------------------------------------------------
# Set to your Vercel app URL so the browser allows API requests (e.g. https://your-app.vercel.app).
# CORS_ORIGIN=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# WHATSAPP (optional)
# -----------------------------------------------------------------------------
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# -----------------------------------------------------------------------------
# NODE ENV (production on Render/Vercel)
# -----------------------------------------------------------------------------
NODE_ENV=production
